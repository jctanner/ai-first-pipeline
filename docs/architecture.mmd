                JobN["... more jobs ..."]
            end
        end
    end

    subgraph Runners["Agent Runner Architecture in Jobs"]
        direction TB

        SDKRunner["SDK Runner: claude_agent_sdk - Fast - MCP v0.1.59+ - Limited persistence"]
        CLIRunner["CLI Runner: claude -p - Full persistence - Native skills - Multi-turn"]

        subgraph Skills["Skills Configuration"]
            LocalSkills["Local: .claude/skills/ - bug-completeness - bug-context-map - bug-fix-attempt - patch-validation - strat.security.review"]
            RemoteSkills["Remote: remote_skills/rfe-creator - rfe.create - rfe.review - rfe.split - strat.create - strat.refine"]
        end

        Templated["Templated: SKILL.md injection - Bug phases"]
        Native["Native: SDK discovery - RFE/Strategy phases"]
    end

    subgraph External["External Services"]
        direction TB
        VertexAI["Vertex AI: Claude API - us-east5"]
        JiraCloud["Jira Cloud: issues.redhat.com"]
        GitHub["GitHub: Code repos"]
    end

    subgraph DataFlow["Pipeline Data Flow"]
        direction TB
        Phase1["1. Fetch Bugs: Jira to issues/*.json"]
        Phase2["2. Run Phases: Orchestrate agents in parallel"]
        Phase3["3. Generate Outputs: workspace/KEY/MODEL/*.json"]
        Phase4["4. Validation: Podman containers optional"]
        Phase5["5. Dashboard: SSE live updates"]

        Phase1 --> Phase2
        Phase2 --> Phase3
        Phase3 --> Phase4
        Phase4 --> Phase5
    end

