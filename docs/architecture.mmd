            end

            subgraph PVCs["Persistent Volume Claims"]
                IssuesPVC["pipeline-issues: Jira JSON"]
                WorkspacePVC["pipeline-workspace: Cloned repos"]
                LogsPVC["pipeline-logs: Agent logs"]
                ArtifactsPVC["pipeline-artifacts: Outputs"]
                ContextPVC["pipeline-context: .context repos"]
            end

            subgraph Secrets["Secrets and ConfigMaps"]
                PipelineSecrets["pipeline-secrets: JIRA_TOKEN, VERTEX_PROJECT_ID, etc"]
