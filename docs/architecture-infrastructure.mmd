graph TB
    Host["Host Machine - NFS Mount"]

    subgraph VM["Vagrant VM - Ubuntu 24.04"]
        direction TB

        subgraph K3s["K3s Cluster - Namespace: ai-pipeline"]
            direction TB

            subgraph Services["Deployed Services - K8s Deployments"]
                Dashboard["Dashboard - K8s Deployment - Flask API + UI - Port 5000 - Job submission endpoint - SSE activity stream"]
                MLflow["MLflow - K8s Deployment - Tracking Server - Port 5000 - ClusterIP: mlflow.ai-pipeline.svc.cluster.local:5000"]
                JiraEmu["Jira Emulator - K8s Deployment - HTTP 32359 - HTTPS 30872 - MCP SSE 30961 - NodePorts"]
                GitHubEmu["GitHub Emulator - K8s Deployment - HTTP 32661 - HTTPS 30783 - NodePorts"]
            end

            subgraph Storage["Persistent Volume Claims"]
                IssuesPVC["pipeline-issues - Jira JSON files"]
                WorkspacePVC["pipeline-workspace - Cloned repos + outputs"]
                LogsPVC["pipeline-logs - Agent execution logs"]
                ArtifactsPVC["pipeline-artifacts - Generated outputs"]
                ContextPVC["pipeline-context - Architecture docs"]
            end

            subgraph Security["Secrets and ConfigMaps"]
                PipelineSecrets["pipeline-secrets - JIRA_TOKEN - VERTEX_PROJECT_ID - CLOUD_ML_REGION"]
                GCPCreds["gcp-credentials - Service account JSON"]
                CACert["internal-ca-cert - TLS certificates"]
            end

            RBAC["RBAC - ServiceAccount: pipeline-agent - Permissions: Jobs, Pods"]
        end

        Docker["Docker - Image builds"]
    end

    Host -.->|NFS sync| Storage

    Dashboard -->|reads| IssuesPVC
    Dashboard -->|reads| WorkspacePVC
    Dashboard -->|reads| LogsPVC

    MLflow -->|writes| ArtifactsPVC

    classDef storage fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef service fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    classDef security fill:#ffebee,stroke:#c62828,stroke-width:2px

    class IssuesPVC,WorkspacePVC,LogsPVC,ArtifactsPVC,ContextPVC storage
    class Dashboard,MLflow,JiraEmu,GitHubEmu service
    class PipelineSecrets,GCPCreds,CACert,RBAC security
