graph TB
    User["User"]

    subgraph Host["Host Machine"]
        Browser["Browser: https://dashboard.local"]
    end

    subgraph VM["Vagrant VM - 8GB RAM - 8 CPU"]
        direction TB

        K3s["K3s Cluster"]
        Storage["Persistent Storage - 5 PVCs"]

        subgraph Services["Cluster Services"]
            Dashboard["Dashboard - https://dashboard.local - Flask API + UI + SSE"]
            MLflow["MLflow - https://mlflow.local - Tracking Server"]
            JiraEmu["Jira Emulator - https://jira.local - MCP Server"]
            GitHubEmu["GitHub Emulator - https://github.local"]
        end

        Jobs["K8s Jobs - Dynamic Parallel Execution"]

        K3s --> Storage
        K3s --> Services
        K3s --> Jobs
        Dashboard -->|creates| Jobs
    end

    subgraph Runners["Agent Runners in Jobs"]
        direction TB
        SDKRunner["SDK Runner: claude_agent_sdk"]
        CLIRunner["CLI Runner: claude -p"]
        Skills["Skills: Local + Remote"]

        SDKRunner --> Skills
        CLIRunner --> Skills
    end

    subgraph External["External Services"]
        direction TB
        VertexAI["Vertex AI: Claude API"]
        JiraCloud["Jira Cloud"]
        GitHub["GitHub"]
    end

    User --> Browser

    Browser -->|submit jobs| Dashboard
    Dashboard -->|SSE stream| Browser

    Jobs --> Runners

    Runners --> VertexAI
    Runners --> MLflow
    Runners --> JiraEmu
    Runners --> JiraCloud
    Runners --> GitHub

    classDef vm fill:#fff3e0,stroke:#f57c00,stroke-width:3px
    classDef runner fill:#fce4ec,stroke:#c2185b,stroke-width:3px
    classDef external fill:#e8f5e9,stroke:#388e3c,stroke-width:3px

    class VM,K3s,Storage,Dashboard,Jobs vm
    class Runners,SDKRunner,CLIRunner,Skills runner
    class External,VertexAI,JiraCloud,GitHub external
